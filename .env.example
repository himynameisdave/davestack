# Copy this file to .env.local and fill in what you need.
# A fresh clone boots with ZERO changes here (sane local-dev defaults live in
# src/lib/server/env.ts) — you only need real values for the integrations you turn on.
# `bun run setup` copies this file and generates a BETTER_AUTH_SECRET for you.

# ── Database ────────────────────────────────────────────────────────────────
# Local dev uses the Docker Compose Postgres: `docker compose up -d db`.
# DATABASE_URL       — pooled connection used by the app at runtime.
# DIRECT_DATABASE_URL — non-pooled, used by the Prisma CLI for migrations.
# Local: identical. Production (Neon/Railway): they differ (pooled vs direct).
DATABASE_URL="postgresql://davestack:davestack@localhost:5432/davestack?schema=public"
DIRECT_DATABASE_URL="postgresql://davestack:davestack@localhost:5432/davestack?schema=public"

# ── Better Auth (required in production) ────────────────────────────────────
# Generate a real secret:  openssl rand -base64 32
# In dev a built-in placeholder is used if this is blank; production BOOT FAILS
# on the placeholder, so you cannot ship without setting it.
BETTER_AUTH_SECRET=
# The canonical origin of the app. Passkeys derive their RP ID + origin from this,
# so it MUST match the URL the browser actually loads (localhost, Railway URL, or
# your custom domain). See the README "Passkeys across environments" section.
BETTER_AUTH_URL="http://localhost:5173"
# Optional: override the passkey Relying Party ID (defaults to BETTER_AUTH_URL's
# hostname). Set only when one app spans multiple subdomains.
# PASSKEY_RP_ID=

# ── Google OAuth (optional) ─────────────────────────────────────────────────
# BOTH must be set for the Google button to render; absent = button hidden, no
# crash. Create credentials at https://console.cloud.google.com → APIs & Services
# → Credentials → OAuth client ID (Web application). Register this redirect URI:
#   {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Resend (optional — transactional email) ─────────────────────────────────
# Absent = emails are printed to the console in dev instead of being sent.
RESEND_API_KEY=
# From address for outbound mail, e.g. "davestack <noreply@yourdomain.com>".
RESEND_FROM_EMAIL=

# ── Umami analytics (optional, production only) ─────────────────────────────
# The tracking script loads only when the website id is set AND NODE_ENV=production
# (never in dev or e2e). Create a site at https://cloud.umami.is.
PUBLIC_UMAMI_WEBSITE_ID=
# Defaults to Umami Cloud; override when self-hosting Umami.
PUBLIC_UMAMI_SRC="https://cloud.umami.is/script.js"
