# Test environment — committed to the repo (no real secrets).
# Vitest and Playwright run against the db-test service (port 5433) so the suite
# never touches dev data. TEST_MODE enables the in-memory mailbox used to assert
# verification / magic-link flows. Finalized in the testing phase.
NODE_ENV="test"
TEST_MODE="1"

DATABASE_URL="postgresql://davestack:davestack@localhost:5433/davestack_test?schema=public"
DIRECT_DATABASE_URL="postgresql://davestack:davestack@localhost:5433/davestack_test?schema=public"

BETTER_AUTH_SECRET="test-secret-not-for-production"
# Must match the Playwright preview server origin (adapter-node preview = 4173).
BETTER_AUTH_URL="http://localhost:4173"
