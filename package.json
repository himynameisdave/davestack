{
  "name": "davestack",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "svelte-kit sync && vite dev",
    "build": "svelte-kit sync && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxlint --config oxlintrc.json --deny-warnings --type-aware --tsconfig ./tsconfig.json",
    "lint:fix": "oxlint --config oxlintrc.json --fix --deny-warnings --type-aware --tsconfig ./tsconfig.json",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "sveltekit-rate-limiter": "^0.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.24.0",
    "@sveltejs/adapter-node": "^5.5.7",
    "@sveltejs/kit": "^2.65.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "mode-watcher": "^1.1.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.22.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.7",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.13"
}
