{
  "name": "davestack",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "svelte-kit sync && prisma generate && vite dev",
    "build": "svelte-kit sync && prisma generate && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && prisma generate && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && prisma generate && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxlint --config oxlintrc.json --deny-warnings --type-aware --tsconfig ./tsconfig.json",
    "lint:fix": "oxlint --config oxlintrc.json --fix --deny-warnings --type-aware --tsconfig ./tsconfig.json",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "svelte-kit sync && prisma generate && prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "setup": "bun scripts/setup.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.6.23",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.23",
    "pg": "^8.22.0",
    "resend": "^6.17.2",
    "sveltekit-rate-limiter": "^0.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.24.0",
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-node": "^5.5.7",
    "@sveltejs/kit": "^2.65.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "mode-watcher": "^1.1.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.22.1",
    "prisma": "^7.8.0",
    "svelte": "^5.56.5",
    "svelte-check": "^4.4.7",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,js,svelte,css,html,json,yaml,yml,md}": "oxfmt --write",
    "*.{ts,js,svelte}": "oxlint --config oxlintrc.json --deny-warnings",
    "*": "bun scripts/check-staged.ts"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.13"
}
